# ====== 环境变量模板:复制为 .env 并填入真实值 ======

# 服务端口(Render 会自动注入 PORT,本地可填 3000)
PORT=3000

# PostgreSQL 连接串
# 本地示例: postgresql://archlearn:archlearn_dev@127.0.0.1:5432/archlearn
# Render 部署时填 Render PostgreSQL 的 Internal Database URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# LLM 配置(OpenAI 兼容接口)
LLM_BASE_URL=https://llm-api.mcisaas.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_STRONG=gpt-5.4
LLM_MODEL_FAST=gpt-5.4-mini

# 会话密钥(生产环境务必改成强随机字符串)
SESSION_SECRET=please-change-to-a-strong-random-string
